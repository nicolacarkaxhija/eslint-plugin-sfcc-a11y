{
  "name": "eslint-plugin-sfcc-a11y",
  "version": "1.0.0-alpha.0",
  "description": "ESLint plugin for WCAG accessibility checks on SFCC ISML templates and library XML content assets",
  "main": "index.js",
  "files": [
    "index.js",
    "lib/"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "sfcc",
    "isml",
    "accessibility",
    "a11y",
    "wcag"
  ],
  "author": "Nicola Carkaxhija",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolacarkaxhija/eslint-plugin-sfcc-a11y.git"
  },
  "bugs": {
    "url": "https://github.com/nicolacarkaxhija/eslint-plugin-sfcc-a11y/issues"
  },
  "homepage": "https://github.com/nicolacarkaxhija/eslint-plugin-sfcc-a11y#readme",
  "peerDependencies": {
    "@html-eslint/parser": ">=0.23.0",
    "eslint": ">=8.0.0"
  },
  "dependencies": {
    "aria-query": "^5.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@html-eslint/parser": "^0.23.0",
    "@vitest/coverage-istanbul": "^2.1.9",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
